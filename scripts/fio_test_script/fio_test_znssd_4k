#!/bin/bash

for var in 1 2 3 4 5
do
    fio --filename=/dev/nvme1n1 --name=fio_zns_test --zonemode=zbd --zonesize=128M --direct=1 --rw=write --size=1z --offset=0 --bs=4K --numjobs=1 --group_reporting=1 --time_based=1 --runtime=300;
